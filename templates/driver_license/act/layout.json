{
  "layout_config": {
    "template": {
      "document": "ACT_DRIVER_LICENCE",
      "dimensions": { "width": 1000, "height": 630 },
      "assets": {
        "front_background_image": "act_front_template_with_labels_baked_in.jpg",
        "back_background_image": "act_back_template_baked_in.jpg"
      },
      "design_tokens": {
        "colors": {
          "text_black": "#000000"
        },
        "fonts": {
          "regular": "Arial",
          "bold": "Arial-Bold"
        }
      }
    },
    "mapping_front": [
      {
        "id": "val_fullname",
        "type": "dynamic_text",
        "data_key": "front.holder.full_name",
        "position": { "x": 40, "y": 130 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_address_line_1",
        "type": "dynamic_text",
        "data_key": "front.address.address_line_1",
        "position": { "x": 40, "y": 160 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_address_line_2",
        "type": "dynamic_text_combined",
        "data_keys": [
          "front.address.suburb",
          "front.address.state",
          "front.address.postcode"
        ],
        "format": "{0} {1} {2}",
        "position": { "x": 40, "y": 190 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_dob",
        "type": "dynamic_text",
        "data_key": "front.holder.dob",
        "position": { "x": 160, "y": 280 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_licence_no",
        "type": "dynamic_text",
        "data_key": "front.licence.licence_number",
        "position": { "x": 160, "y": 320 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_expiry_date",
        "type": "dynamic_text",
        "data_key": "front.licence.expiry_date",
        "position": { "x": 450, "y": 320 },
        "style": { "font": "bold", "size": 18, "color": "text_black" }
      },
      {
        "id": "val_class",
        "type": "dynamic_text_array",
        "data_key": "front.licence.licence_classes",
        "join_with": ",",
        "position": { "x": 160, "y": 360 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_conditions",
        "type": "dynamic_text_array",
        "data_key": "front.licence.conditions",
        "join_with": ",",
        "position": { "x": 160, "y": 400 },
        "style": { "font": "bold", "size": 20, "color": "text_black" }
      },
      {
        "id": "val_vertical_serial",
        "type": "dynamic_text",
        "data_key": "front.card_number",
        "position": { "x": 650, "y": 500, "rotation": -90 },
        "style": { "font": "bold", "size": 14, "color": "text_black" }
      },
      {
        "id": "layer_portrait",
        "type": "image_layer",
        "condition": "front.photo_present == true",
        "fallback": "RANDOM_PORTRAIT",
        "ai_prompt": "Realistic passport style front-facing photo of a young adult male on a white background.",
        "bounding_box": { "x": 700, "y": 180, "width": 240, "height": 300 }
      },
      {
        "id": "layer_signature",
        "type": "image_layer",
        "condition": "front.signature_present == true",
        "fallback": "RANDOM_SIGNATURE",
        "ai_prompt": "Random black ink cursive signature on a transparent background.",
        "bounding_box": { "x": 80, "y": 460, "width": 250, "height": 80 }
      }
    ],
    "mapping_back": [
      {
        "id": "label_conditions_title",
        "type": "static_text",
        "content": "Licence Conditions",
        "position": { "x": 20, "y": 260 },
        "style": { "font": "bold", "size": 16, "color": "text_black" }
      },
      {
        "id": "val_conditions_list",
        "type": "dynamic_dictionary_list",
        "data_key": "back.conditions_legend",
        "format": "{key} - {value}",
        "position": { "x": 20, "y": 290, "line_spacing": 20 },
        "style": { "font": "regular", "size": 14, "color": "text_black", "max_width": 960 }
      },
      {
        "id": "val_barcode",
        "type": "barcode_generator",
        "data_key": "back.barcode_number",
        "barcode_type": "CODE128",
        "bounding_box": { "x": 50, "y": 450, "width": 300, "height": 60 }
      }
    ]
  }
}